{
    "name": "skill-monitor",
    "displayName": "Skill Monitor",
    "description": "Monitors active skills called by the AI agent.",
    "version": "0.0.2",
    "engines": {
        "vscode": "^1.75.0"
    },
    "publisher": "fanfan",
    "license": "MIT",
    "icon": "icon.png",
    "categories": [
        "Other",
        "AI"
    ],
    "keywords": [
        "ai",
        "agent",
        "skills",
        "monitoring",
        "developer-tools"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "skill-monitor.refreshEntry",
                "title": "Refresh Skill",
                "icon": "$(refresh)"
            },
            {
                "command": "skill-monitor.toggle",
                "title": "Start/Stop Monitoring",
                "icon": "$(toggle-on)"
            },
            {
                "command": "skill-monitor.openSkill",
                "title": "Open Skill Documentation"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "skill-monitor.refreshEntry",
                    "when": "view == activeSkillsView || view == availableSkillsView",
                    "group": "navigation"
                },
                {
                    "command": "skill-monitor.toggle",
                    "when": "view == activeSkillsView || view == availableSkillsView",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "skill-monitor-explorer",
                    "title": "Skill Monitor",
                    "icon": "$(zap)"
                }
            ]
        },
        "views": {
            "skill-monitor-explorer": [
                {
                    "type": "webview",
                    "id": "skillMonitorWebView",
                    "name": "⚡️ Skill Dashboard",
                    "icon": "$(zap)"
                }
            ]
        }
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "node ./test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.75.0",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "16.x",
        "eslint": "^8.36.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "typescript": "^4.9.5",
        "@vscode/test-electron": "^2.3.0"
    }
}