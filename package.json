{
    "name": "skill-monitor",
    "displayName": "Skill Monitor",
    "description": "Monitor and manage AI Agent Skills in the .agents/skills directory",
    "version": "0.1.3",
    "engines": {
        "vscode": "^1.90.0"
    },
    "publisher": "fanfan",
    "repository": {
        "type": "git",
        "url": "https://github.com/FANJIYU0825/skill-monitor.git"
    },
    "license": "MIT",
    "icon": "icon.png",
    "categories": [
        "Other",
        "AI"
    ],
    "keywords": [
        "ai",
        "agent",
        "skills",
        "monitoring",
        "developer-tools"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "skill-monitor.refreshEntry",
                "title": "Refresh Skill",
                "icon": "$(refresh)"
            },
            {
                "command": "skill-monitor.toggle",
                "title": "Start/Stop Monitoring",
                "icon": "$(toggle-on)"
            },
            {
                "command": "skill-monitor.openSkill",
                "title": "Open Skill Documentation"
            },
            {
                "command": "skill-monitor.scanSkill",
                "title": "Scan Skill",
                "icon": "$(shield)"
            },
            {
                "command": "skill-monitor.importExamples",
                "title": "Import Example Skills",
                "icon": "$(cloud-download)"
            },
            {
                "command": "skill-monitor.testGoogleAI",
                "title": "Test Google Generative AI",
                "icon": "$(sparkle)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "skill-monitor.refreshEntry",
                    "when": "view == activeSkillsView || view == availableSkillsView",
                    "group": "navigation"
                },
                {
                    "command": "skill-monitor.toggle",
                    "when": "view == activeSkillsView || view == availableSkillsView",
                    "group": "navigation"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "skill-monitor-explorer",
                    "title": "Skill Monitor",
                    "icon": "$(zap)"
                }
            ]
        },
        "views": {
            "skill-monitor-explorer": [
                {
                    "type": "webview",
                    "id": "skillMonitorWebView",
                    "name": "⚡️ Skill Dashboard",
                    "icon": "$(zap)"
                }
            ]
        },
        "configuration": {
            "title": "Skill Monitor",
            "properties": {
                "skill-monitor.googleApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API Key for Google Generative AI (Gemini). Used for AI features.",
                    "ignoreSync": true
                }
            }
        }
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "node ./test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "16.x",
        "@types/vscode": "^1.90.0",
        "@vscode/test-electron": "^2.3.0",
        "eslint": "^8.36.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "typescript": "^4.9.5"
    },
    "dependencies": {
        "@google/genai": "^1.44.0"
    }
}